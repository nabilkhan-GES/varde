# All MVP layers work with NO keys. These unlock optional/roadmap feeds.

# U.S. Energy Information Administration (free): https://www.eia.gov/opendata/
EIA_API_KEY=

# NASA FIRMS active-fire wildfire hotspots (free): get a MAP_KEY at
# https://firms.modaps.eosdis.nasa.gov/api/  → powers the "Wildfire hotspots" layer.
NASA_FIRMS_API_KEY=
FIRMS_MAP_KEY=

# GIE AGSI+ EU gas storage (free): register at https://agsi.gie.eu/account
# → powers the "EU Gas Storage" panel.
GIE_API_KEY=

# ENTSO-E EU electricity transparency (free token): https://transparency.entsoe.eu
# (Account → Web API). Pending wiring — see ROADMAP.
ENTSO_E_TOKEN=

# AISStream (free): register at https://aisstream.io → powers the "Tankers (AIS)"
# layer. The snapshot opens a timed WebSocket sample (no always-on relay needed).
# Optionally override the sample window (ms):
AISSTREAM_API_KEY=
# AIS_SAMPLE_MS=40000

# FRED — US macro drivers (free, instant): https://fredaccount.stlouisfed.org/apikeys
# → powers the "Macro Drivers" panel (USD, rates, inflation, WTI).
FRED_API_KEY=

# Anthropic (for the roadmap AI brief/synthesis feature)
ANTHROPIC_API_KEY=

# Set to 1 to enable the (experimental, noisy) GDELT DOC 2.0 source on the
# incidents layer. Off by default — see ROADMAP v0.2. No key required.
VARDE_GDELT=
