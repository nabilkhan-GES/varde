# All MVP layers work with NO keys. These unlock optional/roadmap feeds.

# U.S. Energy Information Administration (free): https://www.eia.gov/opendata/
EIA_API_KEY=

# NASA FIRMS active-fire (free): https://firms.modaps.eosdis.nasa.gov/api/
FIRMS_MAP_KEY=

# Anthropic (for the roadmap AI brief/synthesis feature)
ANTHROPIC_API_KEY=

# Set to 1 to enable the (experimental, noisy) GDELT DOC 2.0 source on the
# incidents layer. Off by default — see ROADMAP v0.2. No key required.
VARDE_GDELT=
